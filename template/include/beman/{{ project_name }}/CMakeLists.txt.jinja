{% set identity = "identity" if generating_exemplar else "todo" %}

if(BEMAN_{{project_name.upper()}}_USE_MODULES)
    target_sources(
        beman.{{project_name}}
        PUBLIC
            FILE_SET CXX_MODULES FILES {{project_name}}.cppm
