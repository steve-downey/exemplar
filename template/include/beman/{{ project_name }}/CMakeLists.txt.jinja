                FILES
                    config.hpp
                    {{project_name}}.hpp
                    {{identity}}.hpp
                    "${PROJECT_BINARY_DIR}/include/beman/{{project_name}}/config_generated.hpp"
    )
else()
    target_sources(
        beman.{{project_name}}
        PUBLIC
            FILE_SET HEADERS
                FILES
                    config.hpp
                    {{project_name}}.hpp
                    {{identity}}.hpp
                    "${PROJECT_BINARY_DIR}/include/beman/{{project_name}}/config_generated.hpp"
    )
endif()
